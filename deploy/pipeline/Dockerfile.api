# PaddleDetection API Dockerfile
FROM paddlepaddle/paddle:latest

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    libgl1-mesa-glx \
    libglib2.0-0 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# 复制应用代码
COPY api/ /app/

# 安装Python依赖
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    pydantic \
    opencv-python \
    scipy \
    websockets

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["python", "main.py"]
